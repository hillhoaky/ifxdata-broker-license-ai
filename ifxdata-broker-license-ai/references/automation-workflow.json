{
  "workflow": "ifxdata-broker-license-ai-score",
  "version": 8,
  "scope": "global-only",
  "entrypoint": "https://admin.ifxdata.com/dashboard/broker-new?page={page}",
  "ifxdata_access": {
    "preferred_mode": "api",
    "fallback_mode": "supervised_ui_fallback_only",
    "confirmation_reference": "references/ifxdata-admin-api.md",
    "allow_screenshot_primary_extraction": false,
    "require_confirmed_write_contract": true,
    "read_after_write_preference": "api",
    "api_first_reference": "references/api-first-implementation.md"
  },
  "ai_provider": {
    "name": "Google Gemini Web",
    "url": "https://gemini.google.com/app",
    "prompt_version": "gemini-license-score-v1"
  },
  "processing_provider": {
    "name": "Local deterministic parser",
    "script": "scripts/parse_gemini_license_score.py",
    "required_env": null,
    "required_network": [],
    "tasks": ["local_parse", "validate"],
    "codex_fallback": false,
    "private_field_export_allowed": false,
    "redaction_required": false
  },
  "optional_processing_provider": {
    "name": "DeepSeek API",
    "default_model": "deepseek-v4-flash",
    "required_env": "DEEPSEEK_API_KEY",
    "required_network": ["https://api.deepseek.com"],
    "tasks": ["optional_translation", "optional_exception_review", "optional_report"],
    "production_preferred_mode": "ifxdata_backend_deepseek_proxy",
    "blocks_routine_writeback": false,
    "private_field_export_allowed": false,
    "redaction_required": true
  },
  "runtime": {
    "unattended_allowed": true,
    "requires_gemini_signed_in_session": true,
    "requires_ifxdata_global_write_access": true,
    "deepseek_optional": true,
    "default_batch_size_early_rollout": {"brokers": 1, "licenses": 10},
    "default_cadence_after_supervised_success": "PT30M",
    "cursor_required": true,
    "reference": "references/automation-runtime.md"
  },
  "states": [
    "confirm_ifxdata_api",
    "load_endpoint_mapping",
    "discover_endpoints_if_missing",
    "resolve_broker",
    "capture_broker_web_link",
    "read_global_licenses",
    "enumerate_licenses",
    "official_website_precheck",
    "report_precheck_differences",
    "capture_source",
    "check_existing",
    "query_gemini",
    "local_parse_validate",
    "stage_update",
    "save_update",
    "verify_update",
    "record_result",
    "advance_license",
    "optional_deepseek_report",
    "complete"
  ],
  "transitions": [
    {"from": "confirm_ifxdata_api", "on": "api_confirmed", "to": "load_endpoint_mapping", "access_mode": "api"},
    {"from": "confirm_ifxdata_api", "on": "api_unconfirmed", "to": "record_result", "status": "blocked_api_contract_missing"},
    {"from": "load_endpoint_mapping", "on": "mapping_available", "to": "resolve_broker"},
    {"from": "load_endpoint_mapping", "on": "mapping_missing", "to": "discover_endpoints_if_missing", "status": "needs_endpoint_discovery"},
    {"from": "discover_endpoints_if_missing", "on": "confirmed", "to": "resolve_broker"},
    {"from": "discover_endpoints_if_missing", "on": "not_confirmed", "to": "record_result", "status": "blocked_api_contract_missing"},
    {"from": "resolve_broker", "on": "found", "to": "capture_broker_web_link"},
    {"from": "capture_broker_web_link", "on": "captured_or_missing", "to": "read_global_licenses"},
    {"from": "read_global_licenses", "on": "confirmed_global", "to": "enumerate_licenses"},
    {"from": "enumerate_licenses", "on": "licenses_available", "to": "official_website_precheck"},
    {"from": "official_website_precheck", "on": "matched_or_website_unavailable", "to": "capture_source"},
    {"from": "official_website_precheck", "on": "differences_found", "to": "report_precheck_differences", "status": "needs_review"},
    {"from": "report_precheck_differences", "on": "user_corrected_or_authorized_continue", "to": "capture_source"},
    {"from": "capture_source", "on": "valid_identity", "to": "check_existing"},
    {"from": "capture_source", "on": "ambiguous_or_incomplete", "to": "record_result", "status": "needs_review"},
    {"from": "check_existing", "on": "empty_or_overwrite_authorized", "to": "query_gemini"},
    {"from": "check_existing", "on": "existing_and_no_overwrite", "to": "record_result", "status": "skipped_existing"},
    {"from": "query_gemini", "on": "answer_received", "to": "local_parse_validate"},
    {"from": "query_gemini", "on": "blocked_or_refused", "to": "record_result", "status": "blocked"},
    {"from": "local_parse_validate", "on": "valid", "to": "stage_update"},
    {"from": "local_parse_validate", "on": "invalid_or_ambiguous", "to": "record_result", "status": "needs_review"},
    {"from": "stage_update", "on": "identity_match", "to": "save_update"},
    {"from": "stage_update", "on": "identity_mismatch", "to": "record_result", "status": "needs_review"},
    {"from": "save_update", "on": "saved", "to": "verify_update"},
    {"from": "verify_update", "on": "exact_match", "to": "record_result", "status": "completed"},
    {"from": "verify_update", "on": "mismatch_or_unreadable", "to": "record_result", "status": "failed_verification"},
    {"from": "record_result", "on": "recorded", "to": "advance_license"},
    {"from": "advance_license", "on": "more_licenses", "to": "capture_source"},
    {"from": "advance_license", "on": "no_more_licenses", "to": "optional_deepseek_report"},
    {"from": "optional_deepseek_report", "on": "reported_or_skipped", "to": "complete"}
  ],
  "write_fields": ["score", "ai_score_introduction"],
  "guards": {
    "require_global": true,
    "require_official_website_precheck": true,
    "website_unavailable_does_not_block_scoring": true,
    "website_backend_difference_blocks_scoring_until_user_review": true,
    "prefer_ifxdata_api": true,
    "require_api_for_normal_runs": true,
    "require_confirmed_api_write_contract": true,
    "screenshot_primary_extraction_allowed": false,
    "dom_dump_primary_extraction_allowed": false,
    "require_local_parser": true,
    "codex_native_parser_allowed": false,
    "deepseek_blocks_routine_writeback": false,
    "require_deepseek_redaction_for_optional_deepseek": true,
    "private_field_export_allowed": false,
    "require_identity_match": true,
    "require_integer_score_0_100": true,
    "require_english_introduction": true,
    "overwrite_existing_default": false,
    "require_read_after_write": true
  },
  "resume_key": ["broker_id", "license_record_id", "identity_key"],
  "terminal_statuses": ["completed", "skipped_existing", "needs_review", "needs_endpoint_discovery", "blocked", "blocked_api_contract_missing", "blocked_runtime_authorization_required", "failed_verification"]
}
